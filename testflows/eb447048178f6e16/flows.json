    {
        "id": "e671799b9d0a12a2",
        "type": "inject",
        "z": "eb447048178f6e16",
        "name": "",
        "props": [
            {
                "p": "one",
                "v": "$millis()",
                "vt": "jsonata"
            },
            {
                "p": "pause",
                "v": "$flowContext(\"ddd\")",
                "vt": "jsonata"
            },
            {
                "p": "pause2",
                "v": "$flowContext(\"ddd1\")",
                "vt": "str"
            },
            {
                "p": "pause3",
                "v": "$flowContext(\"ddd2\")",
                "vt": "str"
            },
            {
                "p": "pause4",
                "v": "$flowContext(\"ddd3\")",
                "vt": "str"
            },
            {
                "p": "two",
                "v": "$millis()",
                "vt": "jsonata"
            },
            {
                "p": "three",
                "v": "$$.two - $$.one",
                "vt": "jsonata"
            },
            {
                "p": "should_be_zero",
                "v": "$reverse($split( $millis() & \" \" & $flowContext(\"ddd\") & \" \" & $millis() & \" \" & ($millis()  - $millis()), \" \"))[0]",
                "vt": "jsonata"
            }
        ],
