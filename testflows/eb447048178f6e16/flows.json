    {
        "id": "a37d9d97bc0b6647",
        "type": "comment",
        "z": "eb447048178f6e16",
        "g": "4305d2a6e180fe99",
        "name": "Warning might fail",
        "info": "This is time depended test where steps in the second inject node need to take longer than a second. The point is to demostrate that $millis() is the same within one call but differs between separate calls.\n\nFor that, there a couple of $flowContext(..) calls that meant to take non-zero time, collectively they should hit at least one second. This isn't always the case, hence false negatives.",
        "x": 346.5,
        "y": 141,
        "wires": []
    }
